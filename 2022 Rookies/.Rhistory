library(coda)
library(rjags)
##########################################################################################################
# Normal-Normal-Gamma Example
##########################################################################################################
set.seed(99)
# Let's generate some sample data
y=rnorm(100,mean=3,sd=0.75)
n=length(y)
# Setup the input data list for JAGS:
mydata = list(n=n,y=y)
# Setup parameter initialization for JAGS:
myinit = list(beta0=0, tau=1)
# Setup MCMC options for JAGS:
niters=10000  # **total** number of iterations, **including** burn-in
nburns=2500
nadapt=2500
nchains=2
# Specify JAGS model:
mod = "model {
# likelihood
for (i in 1:n) {
y[i] ~ dnorm(mu[i],tau)
mu[i] = beta0
}
# priors
tau ~ dgamma(0.01, 0.01)
beta0 ~ dnorm(0.0, 0.001)
# sigma
sig <- sqrt(1/tau)
}"
# The corresponding JAGS model definition is in normalnormal.txt.
# Now let's setup the model:
fit=jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
# And run it:
fit.samples=coda.samples(fit,c("beta0","sig"),n.iter=niters)
summary(fit.samples)
plot(fit.samples)
# To extract just the post-burnin samples:
summary(window(fit.samples,start=nburns+nadapt))
plot(window(fit.samples,start=nburns+nadapt))
plot(window(fit.samples,start=nburns+nadapt),trace=FALSE)
##########################################################################################################
# Normal-Normal-Gamma Regression Example in 1D
##########################################################################################################
set.seed(7)
# Now let's generate 1 predictor variable
n=1000
x1=runif(n,min=-1,max=1)
y=1.5+10*x1+rnorm(n,mean=0,sd=0.75)
plot(x1,y,pch=20)
# Setup the input data list for JAGS:
mydata = list(n=n,y=y,x1=x1)
# Setup parameter initialization for JAGS:
myinit = list(beta0=0, beta1=0, tau=1)
# Setup MCMC options for JAGS:
niters=50000  # **total** number of iterations, **including** burn-in
nburns=20000
nadapt=20000
nchains=2
mod = "model {
# likelihood
for (i in 1:n) {
y[i] ~ dnorm(mu[i],tau)
mu[i] <- beta0+beta1*x1[i]
}
# priors
tau ~ dgamma(0.01, 0.01)
beta0 ~ dnorm(0.0, 0.01)
beta1 ~ dnorm(0.0, 0.01)
# sigma
sig <- sqrt(1/tau)
}"
# The corresponding JAGS model definition is in normalnormalregression.txt.
# Now let's setup the model:
fit=jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
# And run it:
fit.samples=coda.samples(fit,c("beta0","beta1","sig"),n.iter=niters)
summary(fit.samples)
plot(fit.samples)
# To extract just the post-burnin samples:
summary(window(fit.samples,start=nburns+nadapt))
