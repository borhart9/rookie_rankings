##########################################################################################################
set.seed(99)
# Let's generate some sample data
y=rnorm(100,mean=3,sd=0.75)
n=length(y)
# Setup the input data list for JAGS:
mydata = list(n=n,y=y)
# Setup parameter initialization for JAGS:
myinit = list(beta0=0, tau=1)
# Setup MCMC options for JAGS:
niters=10000  # **total** number of iterations, **including** burn-in
nburns=2500
nadapt=2500
nchains=2
# Specify JAGS model:
mod = "model {
# likelihood
for (i in 1:n) {
y[i] ~ dnorm(mu[i],tau)
mu[i] = beta0
}
# priors
tau ~ dgamma(0.01, 0.01)
beta0 ~ dnorm(0.0, 0.001)
# sigma
sig <- sqrt(1/tau)
}"
# The corresponding JAGS model definition is in normalnormal.txt.
# Now let's setup the model:
fit=jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
# The corresponding JAGS model definition is in normalnormal.txt.
# Now let's setup the model:
fit=jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
# The corresponding JAGS model definition is in normalnormal.txt.
# Now let's setup the model:
fit=rjags::jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
# The corresponding JAGS model definition is in normalnormal.txt.
# Now let's setup the model:
fit=jags.model(textConnection(mod),
data=mydata, inits=myinit, n.chains=nchains, n.adapt=nadapt)
